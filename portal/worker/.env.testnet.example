# PREFERRED: Use a YAML config file instead of env vars.
# Copy ../server/portal-config.testnet.example.yaml to ../server/portal-config.yaml.
# The webpack build will read it automatically.
# You can also set PORTAL_CONFIG to point to a custom path.
#
# IMPORTANT: For the worker, both YAML and env values are baked into the
# bundle at webpack BUILD TIME via DefinePlugin — they are NOT read at
# runtime. Changing these requires a rebuild. Env vars listed below override
# the YAML at build time.

# --- Worker config (env vars below override YAML) ---
PORTAL_DOMAIN_NAME_LENGTH="21"
SUINS_CLIENT_NETWORK="testnet"
ORIGINAL_PACKAGE_ID="0xf99aee9f21493e1590e7e5a9aea6f343a1f381031a04a732724871fc294be799"
# Boolean vars: only the exact string "true" enables — any other value means false.
ENABLE_GLOB_ROUTING="false"

# Priority URL lists — format: URL|RETRIES|METRIC (lower metric = higher priority).
# Due to the complex syntax of these env vars, it is advised to set them via yaml instead.
# RPC_URL_LIST="https://fullnode.testnet.sui.io|2|100"
# AGGREGATOR_URL_LIST="https://aggregator.walrus-testnet.walrus.space|2|100"

# Per-attempt timeout (ms) for a single aggregator HTTP fetch.
AGGREGATOR_REQUEST_TIMEOUT_MS="10000"
# Per-request timeout (ms) for a single Sui RPC call.
RPC_REQUEST_TIMEOUT_MS="7000"
