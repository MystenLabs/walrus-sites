{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"lib": [
			"esnext",
			"webworker",
			"dom"
		],
		"types": [],
		"baseUrl": "./",
		"rootDir": "../",
		"outDir": "dist",
		"skipLibCheck": true,
		"paths": {
			"@lib/*": [
				"../common/lib/src/*"
			],
			"@templates/*": [
				"../common/html_templates/*"
			]
		}
	},
	"include": [
		"src/**/*",
		"../common/lib/src/**/*",
		"../common/html_templates/*",
	],
	"exclude": [
		"node_modules",
		"dist",
	]
}
