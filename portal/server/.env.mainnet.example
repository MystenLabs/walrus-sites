# PREFERRED: Use a YAML config file instead of env vars.
# See portal-config.mainnet.example.yaml for the schema.
# Copy it to portal-config.yaml and set PORTAL_CONFIG if needed.
#
# Env vars below are supported as overrides — if both YAML and env var
# are set for a field, the env var wins.

# --- Portal config (env vars below override YAML) ---
ENABLE_ALLOWLIST=false
ENABLE_BLOCKLIST=false
LANDING_PAGE_OID_B36=46f3881sp4r55fc6pcao9t93bieeejl4vr4k2uv8u4wwyx1a93
PORTAL_DOMAIN_NAME_LENGTH=21
SUINS_CLIENT_NETWORK=mainnet
ORIGINAL_PACKAGE_ID=0x26eb7ee8688da02c5f671679524e379f0b837a12f1d1d799f255b7eea260ad27
B36_DOMAIN_RESOLUTION_SUPPORT=true
PROMETHEUS_EXPORTER_PORT=9184

# Priority URL lists — format: URL|RETRIES|METRIC (lower metric = higher priority).
# Due to the complex syntax of these env vars, it is advised to set them via yaml instead.
# PREMIUM_RPC_URL_LIST=https://fullnode.mainnet.sui.io|2|100
# RPC_URL_LIST=https://fullnode.mainnet.sui.io|2|100
# AGGREGATOR_URL_LIST=https://aggregator.walrus-mainnet.walrus.space|3|100

# --- Timeouts (env vars only, no YAML equivalent) ---
# Per-attempt timeout (ms) for a single aggregator HTTP fetch.
# Set below any upstream proxy/CDN timeout in front of the portal.
AGGREGATOR_REQUEST_TIMEOUT_MS=10000
# Per-request timeout (ms) for a single Sui RPC call (used by RPCSelector
# for failover between RPC URLs).
RPC_REQUEST_TIMEOUT_MS=7000
# Upper bound (seconds) on the Bun server idleTimeout. Computed from the
# aggregator retry budget at startup, then clamped to this value. Set below
# the upstream proxy/CDN request timeout (e.g. Cloudflare free-tier: 100s).
# Note: Bun's `idleTimeout` accepts at most 255s — values above that are
# rejected or clamped by Bun.
PORTAL_IDLE_TIMEOUT_MAX_S=100

# --- Secrets (env vars only, no YAML equivalent) ---
# BLOCKLIST_REDIS_URL=
# ALLOWLIST_REDIS_URL=
# EDGE_CONFIG=
# EDGE_CONFIG_ALLOWLIST=
